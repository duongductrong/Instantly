# SwiftFormat Configuration for Instantly

# Format options
--indent 4
--indentcase false
--trimwhitespace always
--voidtype void
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapconditions after-first
--wrapreturntype if-multiline
--maxwidth 120
--closingparen balanced
--commas always
--decimalgrouping 3
--elseposition same-line
--guardelse next-line
--header strip
--ifdef no-indent
--importgrouping alpha
--operatorfunc spaced
--ranges spaced
--self init-only
--semicolons never
--stripunusedargs closure-only
--swiftversion 5.9
--trailingclosures
--funcattributes prev-line
--typeattributes prev-line
--varattributes same-line

# Enabled rules (default + extras)
--enable blankLinesBetweenScopes
--enable blankLinesAtStartOfScope
--enable blankLinesAtEndOfScope
--enable consecutiveBlankLines
--enable consecutiveSpaces
--enable duplicateImports
--enable isEmpty
--enable redundantInit
--enable redundantLet
--enable redundantNilInit
--enable redundantParens
--enable redundantReturn
--enable redundantSelf
--enable redundantType
--enable redundantVoidReturnType
--enable sortImports
--enable trailingCommas
--enable trailingSpace
--enable wrapMultilineStatementBraces

# Disabled rules
--disable blankLinesAroundMark
--disable sortDeclarations

# Excluded paths
--exclude .build,DerivedData,Pods,.claude
